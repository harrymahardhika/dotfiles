#!/bin/bash

set -euo pipefail

# Check if running as root
if [ "$EUID" -eq 0 ]; then
    echo "❌ Please don't run this script as root. Use sudo only where needed."
    exit 1
fi

# Prevent concurrent runs
exec 9>/tmp/updateall.lock
if ! flock -n 9; then
    echo "❌ Another instance of updateall is already running."
    exit 1
fi

START_TIME=$(date +%s)
STARTED_AT=$(date)

echo "🔄 Starting system updates..."
echo "⏰ Started at $STARTED_AT"

# Sudo preflight: notify before password prompt, authenticate once, then keep ticket alive.
if ! sudo -n true 2>/dev/null; then
    if command -v notify-send &> /dev/null; then
        notify-send -u critical "sudo password required" "updateall needs elevated privileges"
    fi
    printf '\a'
fi

if ! sudo -v; then
    echo "❌ Failed to authenticate with sudo."
    exit 1
fi

( while true; do sudo -n true; sleep 50; kill -0 "$$" || exit; done ) 2>/dev/null 9>&- &
SUDO_KEEPALIVE_PID=$!
trap 'kill "$SUDO_KEEPALIVE_PID" 2>/dev/null || true' EXIT

if [ -f /etc/arch-release ]; then
    # For Arch-based systems

    # --- Mirror connectivity pre-flight ---
    check_mirrors() {
        local mirrorlist="/etc/pacman.d/mirrorlist"
        if [ ! -f "$mirrorlist" ]; then
            echo "⚠️  Mirrorlist not found, skipping mirror check."
            return 0
        fi

        # Collect active (non-commented) Server lines
        local mirrors=()
        while IFS= read -r line; do
            [[ "$line" =~ ^[[:space:]]*Server[[:space:]]*=[[:space:]]*(.*) ]] && \
                mirrors+=("${BASH_REMATCH[1]}")
        done < "$mirrorlist"

        if [ ${#mirrors[@]} -eq 0 ]; then
            echo "⚠️  No active mirrors found in mirrorlist, skipping mirror check."
            return 0
        fi

        echo "🌐 Checking pacman mirrors..."

        local tmpdir
        tmpdir=$(mktemp -d)
        local idx=0
        local pids=()

        for mirror in "${mirrors[@]}"; do
            local url="${mirror/\$repo\/os\/\$arch/core/os/x86_64}"
            local host
            host=$(echo "$url" | sed -E 's|https?://([^/]+).*|\1|')

            (
                local curl_exit=0 http_code
                http_code=$(curl -sI --connect-timeout 5 --max-time 10 \
                    --write-out '%{http_code}' --output /dev/null "$url" 2>/dev/null) \
                    || curl_exit=$?

                case $curl_exit in
                    0|22) echo "  ✅ $host (HTTP $http_code)" ;;
                    6)   echo "  ❌ $host — DNS resolution failed" ;;
                    28)  echo "  ⏱️  $host — timed out" ;;
                    35|60|51)
                         echo "  🔒 $host — SSL/certificate error (curl exit $curl_exit)" ;;
                    *)   echo "  ⚠️  $host — unreachable (curl exit $curl_exit)" ;;
                esac > "$tmpdir/$idx"

                case $curl_exit in
                    0|22) exit 0 ;;
                    *)     exit 1 ;;
                esac
            ) &
            pids+=($!)
            (( ++idx ))
        done

        local ok=0 failed=0
        idx=0
        for pid in "${pids[@]}"; do
            wait "$pid" 2>/dev/null && (( ++ok )) || (( ++failed ))
            cat "$tmpdir/$idx" 2>/dev/null
            (( ++idx ))
        done

        rm -rf "$tmpdir"

        echo ""
        echo "  Mirror summary: ✅ $ok reachable, ❌ $failed unreachable (out of ${#mirrors[@]} checked)"

        if [ "$failed" -gt 0 ] && [ "$ok" -eq 0 ]; then
            echo "❌ All mirrors are unreachable."
            if [ -z "${MIRROR_RETRIED:-}" ]; then
                echo "🔄 Auto-refreshing mirrorlist..."
                if ! command -v reflector &> /dev/null; then
                    echo "📦 Installing reflector..."
                    sudo pacman -S reflector --noconfirm
                fi
                sudo reflector --latest 10 --protocol https --sort rate \
                    --save /tmp/updateall_mirrorlist
                if [ -s /tmp/updateall_mirrorlist ]; then
                    sudo cp /etc/pacman.d/mirrorlist \
                        "/etc/pacman.d/mirrorlist.bak.$(date +%s)"
                    sudo mv /tmp/updateall_mirrorlist /etc/pacman.d/mirrorlist
                    MIRROR_RETRIED=1 check_mirrors
                    return $?
                fi
                rm -f /tmp/updateall_mirrorlist
                echo "⚠️  Reflector could not generate a mirrorlist."
                exit 1
            else
                echo "❌ Mirror refresh did not resolve the issue. Aborting."
                exit 1
            fi
        fi

        if [ "$failed" -gt 0 ]; then
            echo "⚠️  Some mirrors are unreachable. pacman will skip them automatically."
            echo "   You may want to run 'reflector' to refresh your mirrorlist."
        fi
        echo ""
    }

    check_mirrors

    echo "📦 Updating Arch packages..."

    # Clean up stale Node.js install remnants that can block pacman upgrades.
    # These paths are typically left behind by a previous manual/npm-based global install.
    for dir in npm node-gyp; do
        p="/usr/lib/node_modules/$dir"
        if [ -d "$p" ] && ! pacman -Qo "$p" >/dev/null 2>&1; then
            echo "🧹 Removing stale unowned files: $dir"
            sudo rm -rf "$p"
        fi
    done

    # Clean up stale pacman download temp files from previous interrupted runs
    if ls /var/cache/pacman/pkg/download-* >/dev/null 2>&1; then
        echo "🧹 Removing stale pacman download temp files..."
        sudo rm -f /var/cache/pacman/pkg/download-*
    fi

    sudo pacman -Syu --noconfirm --overwrite '/usr/lib/node_modules/*' || retry=$?
    if [ "${retry:-0}" -ne 0 ]; then
        echo "⚠️  pacman encountered errors (exit $retry). Cleaning and retrying..."
        sudo rm -f /var/cache/pacman/pkg/download-*
        sudo pacman -Syu --noconfirm --overwrite '/usr/lib/node_modules/*' || \
            echo "⚠️  pacman update failed on retry, skipping..."
    fi

    if command -v paru &> /dev/null; then
        echo "📦 Updating AUR packages..."
        paru -Sua --noconfirm || echo "⚠️  paru update failed, skipping..."
    elif command -v yay &> /dev/null; then
        echo "📦 Updating AUR packages with yay..."
        yay -Sua --noconfirm || echo "⚠️  yay update failed, skipping..."
    fi

    # Remove orphan packages only if they exist
    orphans=$(pacman -Qdtq 2>/dev/null || true)
    if [ -n "$orphans" ]; then
        echo "🗑️  Removing orphan packages..."
        echo "$orphans" | xargs sudo pacman -Rns --noconfirm
    fi

    echo "🧹 Cleaning package cache..."
    if command -v paccache &> /dev/null; then
        sudo paccache -rk3 --noconfirm
    else
        sudo pacman -Sc --noconfirm
    fi
else
    # For Ubuntu/Pop!_OS-based systems
    echo "📦 Updating Ubuntu/Debian packages..."
    sudo apt update
    sudo apt upgrade -y --allow-downgrades
    sudo apt autopurge -y && sudo apt autoremove -y && sudo apt clean

    if command -v pacstall &> /dev/null; then
        echo "📦 Updating Pacstall..."
        pacstall -U --disable-prompts || echo "⚠️  Pacstall tool update failed, skipping..." # Update pacstall tool itself
        pacstall -Up --disable-prompts || echo "⚠️  Pacstall packages update failed, skipping..." # Update all installed pacstall packages
    fi
fi

# Update Flatpak
if command -v flatpak &> /dev/null; then
    echo "📦 Updating Flatpak packages..."
    flatpak update -y || echo "⚠️  Flatpak update failed, skipping..."
fi

# Update Snap
if command -v snap &> /dev/null; then
    echo "📦 Updating Snap packages..."
    sudo snap refresh || echo "⚠️  Snap refresh failed, skipping..."
fi

# Update Composer
if command -v composer &> /dev/null; then
    echo "🎼 Updating Composer..."
    composer global self-update --quiet || echo "⚠️  Composer self-update failed, skipping..."
    composer global update --no-progress --profile || echo "⚠️  Composer global update failed, skipping..."
fi

# Update npm global packages
if command -v npm &> /dev/null; then
    echo "📦 Updating npm global packages..."
    sudo npm update -g --silent || echo "⚠️  npm global update failed, skipping..."
fi

# Update pnpm
if command -v pnpm &> /dev/null; then
    echo "📦 Updating pnpm global packages..."
    pnpm update -g || echo "⚠️  pnpm global update failed, skipping..."
fi

# Update uv
if command -v uv &> /dev/null; then
    echo "🐍 Updating uv..."
    timeout 120 uv self update --quiet || echo "⚠️  UV update timed out or failed, skipping..."

    echo "🔧 Updating uv tools..."
    uv tool upgrade --all --quiet
fi

echo ""
echo "✅ All updates completed!"
echo ""
echo "📊 Summary:"
if [ -f /etc/arch-release ]; then
    if command -v paru &> /dev/null; then
        echo "  • Used paru for AUR packages"
    elif command -v yay &> /dev/null; then
        echo "  • Used yay for AUR packages (fallback)"
    fi
    echo "  • Package cache cleaned"
    echo "  • Orphaned packages removed"
else
    echo "  • System packages updated and cleaned"
fi

COMPLETED_AT=$(date)
ELAPSED=$(( $(date +%s) - START_TIME ))
HOURS=$(( ELAPSED / 3600 ))
MINUTES=$(( (ELAPSED % 3600) / 60 ))
SECS=$(( ELAPSED % 60 ))

echo ""
echo "📈 Stats:"
echo "  • Started at: $STARTED_AT"
echo "  • Completed at: $COMPLETED_AT"
if [ $HOURS -gt 0 ]; then
    echo "  • Elapsed time: ${HOURS}h ${MINUTES}m ${SECS}s"
    ELAPSED_STR="${HOURS}h ${MINUTES}m ${SECS}s"
elif [ $MINUTES -gt 0 ]; then
    echo "  • Elapsed time: ${MINUTES}m ${SECS}s"
    ELAPSED_STR="${MINUTES}m ${SECS}s"
else
    echo "  • Elapsed time: ${SECS}s"
    ELAPSED_STR="${SECS}s"
fi

if command -v notify-send &> /dev/null; then
    notify-send -u normal "✅ System update complete" "All packages updated in ${ELAPSED_STR}"
fi
