#!/bin/bash

set -e

# Check if running as root
if [ "$EUID" -eq 0 ]; then
    echo "❌ Please don't run this script as root. Use sudo only where needed."
    exit 1
fi

echo "🔄 Starting system updates..."
echo "⏰ Started at $(date)"

# Sudo preflight: notify before password prompt, authenticate once, then keep ticket alive.
if ! sudo -n true 2>/dev/null; then
    if command -v notify-send &> /dev/null; then
        notify-send -u critical "sudo password required" "updateall needs elevated privileges"
    fi
    printf '\a'
fi

if ! sudo -v; then
    echo "❌ Failed to authenticate with sudo."
    exit 1
fi

( while true; do sudo -n true; sleep 50; kill -0 "$$" || exit; done ) 2>/dev/null &
SUDO_KEEPALIVE_PID=$!
trap 'kill "$SUDO_KEEPALIVE_PID" 2>/dev/null || true' EXIT

if [ -f /etc/arch-release ]; then
    # For Arch-based systems
    echo "📦 Updating Arch packages..."
    sudo pacman -Syu --noconfirm

    if command -v paru &> /dev/null; then
        echo "📦 Updating AUR packages..."
        paru -Sua --noconfirm || echo "⚠️  paru update failed, skipping..."
    elif command -v yay &> /dev/null; then
        echo "📦 Updating AUR packages with yay..."
        yay -Sua --noconfirm || echo "⚠️  yay update failed, skipping..."
    fi

    # Remove orphan packages only if they exist
    orphans=$(pacman -Qdtq 2>/dev/null || true)
    if [ -n "$orphans" ]; then
        echo "🗑️  Removing orphan packages..."
        echo "$orphans" | xargs sudo pacman -Rns --noconfirm
    fi

    echo "🧹 Cleaning package cache..."
    sudo pacman -Scc --noconfirm
else
    # For Ubuntu/Pop!_OS-based systems
    echo "📦 Updating Ubuntu/Debian packages..."
    sudo apt update
    sudo apt upgrade -y --allow-downgrades
    sudo apt autopurge -y && sudo apt autoremove -y && sudo apt clean

    if command -v pacstall &> /dev/null; then
        echo "📦 Updating Pacstall..."
        pacstall -U --disable-prompts || echo "⚠️  Pacstall tool update failed, skipping..." # Update pacstall tool itself
        pacstall -Up --disable-prompts || echo "⚠️  Pacstall packages update failed, skipping..." # Update all installed pacstall packages
    fi
fi

# Update Flatpak
if command -v flatpak &> /dev/null; then
    echo "📦 Updating Flatpak packages..."
    flatpak update -y || echo "⚠️  Flatpak update failed, skipping..."
fi

# Update Snap
if command -v snap &> /dev/null; then
    echo "📦 Updating Snap packages..."
    sudo snap refresh || echo "⚠️  Snap refresh failed, skipping..."
fi

# Update Composer
if command -v composer &> /dev/null; then
    echo "🎼 Updating Composer..."
    composer global self-update --quiet || echo "⚠️  Composer self-update failed, skipping..."
    composer global update --no-progress --profile || echo "⚠️  Composer global update failed, skipping..."
fi

# Update npm global packages
if command -v npm &> /dev/null; then
    echo "📦 Updating npm global packages..."
    npm update -g --silent || echo "⚠️  npm global update failed, skipping..."
fi

# Update pnpm
if command -v pnpm &> /dev/null; then
    echo "📦 Updating pnpm..."
    pnpm self-update || echo "⚠️  pnpm self-update failed, skipping..."
    pnpm update -g || echo "⚠️  pnpm global update failed, skipping..."
fi

# Update uv
if command -v uv &> /dev/null; then
    echo "🐍 Updating uv..."
    timeout 120 uv self update --quiet || echo "⚠️  UV update timed out or failed, skipping..."

    echo "🔧 Updating uv tools..."
    uv tool upgrade --all --quiet
fi

echo ""
echo "✅ All updates completed!"
echo ""
echo "📊 Summary:"
if [ -f /etc/arch-release ]; then
    if command -v paru &> /dev/null; then
        echo "  • Used paru for AUR packages"
    elif command -v yay &> /dev/null; then
        echo "  • Used yay for AUR packages (fallback)"
    fi
    echo "  • Package cache cleaned"
    echo "  • Orphaned packages removed"
else
    echo "  • System packages updated and cleaned"
fi
